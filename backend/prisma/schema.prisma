generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("support")
  created_at    DateTime @default(now())
}

model Transaction {
  id           Int      @id @default(autoincrement())
  client_name  String
  client_email String
  amount       Float
  type         String   // "Deposit" or "Withdrawal"
  method       String
  account      String
  status       String   @default("pending") // pending, completed, processing, failed
  created_at   DateTime @default(now())
}
